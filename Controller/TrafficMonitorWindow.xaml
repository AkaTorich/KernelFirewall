<Window x:Class="FirewallController.TrafficMonitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔍 Traffic Monitor"
        WindowState="Maximized"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundDarkBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="{StaticResource MainFont}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Controls -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="{Binding IsMonitoring, Converter={StaticResource BoolToMonitorTextConverter}}" 
                            Style="{StaticResource NeonButton}" Padding="20,10" FontSize="14"
                            Command="{Binding ToggleMonitoringCommand}"/>
                    <Button Content="🗑️ ОЧИСТИТЬ" Style="{StaticResource DangerButton}" 
                            Padding="20,10" Margin="15,0,0,0" FontSize="14"
                            Command="{Binding ClearTrafficCommand}"/>
                    <Button Content="⟳" Style="{StaticResource NeonButton}" 
                            Padding="15,10" Margin="15,0,0,0" FontSize="16"
                            Command="{Binding RefreshTrafficCommand}"/>
                </StackPanel>

                <!-- Filters -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <CheckBox Style="{StaticResource NeonCheckBox}" Content="TCP" FontSize="14"
                              IsChecked="{Binding ShowTcp}" Margin="0,0,25,0"/>
                    <CheckBox Style="{StaticResource NeonCheckBox}" Content="UDP" FontSize="14"
                              IsChecked="{Binding ShowUdp}" Margin="0,0,25,0"/>
                    <CheckBox Style="{StaticResource NeonCheckBox}" Content="Blocked" FontSize="14"
                              IsChecked="{Binding ShowBlocked}" Foreground="{StaticResource AccentRedBrush}" Margin="0,0,25,0"/>
                    <CheckBox Style="{StaticResource NeonCheckBox}" Content="Allowed" FontSize="14"
                              IsChecked="{Binding ShowAllowed}" Foreground="{StaticResource AccentGreenBrush}"/>
                </StackPanel>

                <!-- Search -->
                <TextBox Grid.Column="2" Style="{StaticResource NeonTextBox}" 
                         Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                         Width="250" Padding="12,8" FontSize="14">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="600"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="600" MinWidth="500"/>
            </Grid.ColumnDefinitions>

            <!-- Traffic List -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="📡 LIVE TRAFFIC" 
                               FontSize="16" FontWeight="Bold" 
                               Foreground="{StaticResource AccentCyanBrush}" 
                               Margin="0,0,0,15"/>

                    <ListBox Grid.Row="1" 
                             x:Name="TrafficListBox"
                             Style="{StaticResource NeonListBox}"
                             ItemsSource="{Binding TrafficEntries}"
                             SelectedItem="{Binding SelectedEntry}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="55"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Time -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}"
                                               FontFamily="{StaticResource MonoFont}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="12" VerticalAlignment="Center"/>

                                    <!-- Protocol -->
                                    <Border Grid.Column="1" CornerRadius="4" Padding="6,2"
                                            HorizontalAlignment="Left" Margin="5,0" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#302196F3"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Protocol}" Value="UDP">
                                                        <Setter Property="Background" Value="#30FF9800"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding ProtocolText}" FontSize="11" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#2196F3"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Protocol}" Value="UDP">
                                                            <Setter Property="Foreground" Value="#FF9800"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <!-- IP Version -->
                                    <Border Grid.Column="2" CornerRadius="4" Padding="6,2"
                                            HorizontalAlignment="Left" Margin="5,0" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#3000FF88"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IpVersion}" Value="IPv6">
                                                        <Setter Property="Background" Value="#30FF00FF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding IpVersion}" FontSize="10" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#00FF88"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IpVersion}" Value="IPv6">
                                                            <Setter Property="Foreground" Value="#FF00FF"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <!-- Direction -->
                                    <TextBlock Grid.Column="3" Text="{Binding DirectionArrow}"
                                               FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Direction}" Value="Inbound">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentMagentaBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Address -->
                                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ProcessName}"
                                                   Foreground="{StaticResource AccentOrangeBrush}"
                                                   FontWeight="SemiBold" FontSize="12"
                                                   Width="120" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Summary}"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="12" Margin="15,0,0,0"/>
                                    </StackPanel>

                                    <!-- Language -->
                                    <TextBlock Grid.Column="5"
                                               Text="{Binding PathLanguage}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentCyanBrush}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>

                                    <!-- Status -->
                                    <Border Grid.Column="6" CornerRadius="4" Padding="10,4" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#2000FF88"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding WasBlocked}" Value="True">
                                                        <Setter Property="Background" Value="#30FF3366"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="10" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="OK"/>
                                                    <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding WasBlocked}" Value="True">
                                                            <Setter Property="Text" Value="BLOCKED"/>
                                                            <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource NeonListBoxItem}">
                                <Setter Property="Padding" Value="10,6"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="8" Background="Transparent" 
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <!-- Details Panel -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="📋 PACKET DETAILS" 
                               FontSize="16" FontWeight="Bold" 
                               Foreground="{StaticResource AccentMagentaBrush}" 
                               Margin="0,0,0,15"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- No selection message -->
                            <TextBlock Text="← Выберите пакет слева для просмотра деталей"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontStyle="Italic" FontSize="14" TextWrapping="Wrap"
                                       Visibility="{Binding FrozenEntry, Converter={StaticResource NullToVisibilityConverter}}"/>

                            <!-- Details -->
                            <StackPanel Visibility="{Binding FrozenEntry, Converter={StaticResource NotNullToVisibilityConverter}}">
                                
                                <!-- Status Banner -->
                                <Border CornerRadius="10" Padding="20,12" Margin="0,0,0,20">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#2000FF88"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding FrozenEntry.WasBlocked}" Value="True">
                                                    <Setter Property="Background" Value="#30FF3366"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding FrozenEntry.StatusText}" 
                                               FontSize="20" FontWeight="Bold" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FrozenEntry.WasBlocked}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>

                                <!-- ETHERNET Frame -->
                                <Border Background="#12FFFFFF" CornerRadius="8" Padding="15" Margin="0,0,0,12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Border Background="#5000BFFF" CornerRadius="5" Padding="10,4">
                                                <TextBlock Text="⬡ ETHERNET II" FontWeight="Bold" FontSize="12" Foreground="#00BFFF"/>
                                            </Border>
                                            <TextBlock Text="Layer 2 - Data Link" Foreground="{StaticResource TextSecondaryBrush}" 
                                                       FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </StackPanel>
                                        <Grid Margin="8,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="EtherType:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FrozenEntry.EtherType}" FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,3" Foreground="#00BFFF"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Src MAC:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FrozenEntry.SourceMac}" FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,3" Foreground="#00BFFF"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Dst MAC:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FrozenEntry.DestinationMac}" FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,3" Foreground="#00BFFF"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- IP Header -->
                                <Border Background="#1200FF88" CornerRadius="8" Padding="15" Margin="0,0,0,12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Border Background="#5000FF88" CornerRadius="5" Padding="10,4">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="◉ " FontWeight="Bold" FontSize="12" Foreground="#00FF88"/>
                                                    <TextBlock Text="{Binding FrozenEntry.IpVersionHeader}" FontWeight="Bold" FontSize="12" Foreground="#00FF88"/>
                                                </StackPanel>
                                            </Border>
                                            <TextBlock Text="Layer 3 - Network" Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </StackPanel>
                                        <Grid Margin="8,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Version:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FrozenEntry.IpVersionHeader}" FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,3" Foreground="#00FF88"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Header Length:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FrozenEntry.IpHeaderLen}" FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Total Length:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FrozenEntry.IpTotalLenText}" FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="TTL:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding FrozenEntry.IpTtlText}" FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,3" Foreground="#FFAA00"/>
                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Protocol:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding FrozenEntry.IpProtocolInfo}" FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,3" Foreground="#00FF88"/>
                                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Source IP:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding FrozenEntry.LocalIpOnly}" FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,3" Foreground="{StaticResource AccentCyanBrush}"/>
                                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Destination IP:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding FrozenEntry.RemoteIpOnly}" FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,3" Foreground="{StaticResource AccentMagentaBrush}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- TCP/UDP Header -->
                                <Border CornerRadius="8" Padding="15" Margin="0,0,0,12">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#122196F3"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding FrozenEntry.Protocol}" Value="UDP">
                                                    <Setter Property="Background" Value="#12FF9800"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Border CornerRadius="5" Padding="10,4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#502196F3"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding FrozenEntry.Protocol}" Value="UDP">
                                                                <Setter Property="Background" Value="#50FF9800"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontWeight="Bold" FontSize="12">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="⬢ TCP"/>
                                                            <Setter Property="Foreground" Value="#2196F3"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding FrozenEntry.Protocol}" Value="UDP">
                                                                    <Setter Property="Text" Value="◆ UDP"/>
                                                                    <Setter Property="Foreground" Value="#FF9800"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            <TextBlock Text="Layer 4 - Transport" Foreground="{StaticResource TextSecondaryBrush}" 
                                                       FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </StackPanel>
                                        <Grid Margin="8,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Source Port:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FrozenEntry.LocalPortOnly}" FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,3" Foreground="{StaticResource AccentCyanBrush}"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Destination Port:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FrozenEntry.RemotePortOnly}" FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,3" Foreground="{StaticResource AccentMagentaBrush}"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Header Length:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FrozenEntry.TransportHeaderSize}" FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Flags:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding FrozenEntry.TcpFlagsText}" FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,3" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#2196F3"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding FrozenEntry.Protocol}" Value="UDP">
                                                                <Setter Property="Foreground" Value="#FF9800"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Seq Number:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding FrozenEntry.TcpSeqText}" FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Ack Number:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding FrozenEntry.TcpAckText}" FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Window Size:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding FrozenEntry.TcpWindowText}" FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,3"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Application Layer -->
                                <Border Background="#12FF5555" CornerRadius="8" Padding="15" Margin="0,0,0,12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Border Background="#50FF5555" CornerRadius="5" Padding="10,4">
                                                <TextBlock Text="⬤ APPLICATION" FontWeight="Bold" FontSize="12" Foreground="#FF5555"/>
                                            </Border>
                                            <TextBlock Text="Layer 7" Foreground="{StaticResource TextSecondaryBrush}" 
                                                       FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </StackPanel>
                                        <Grid Margin="8,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Process:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FrozenEntry.ProcessName}" FontWeight="Bold" FontSize="12" Margin="0,3" Foreground="{StaticResource AccentOrangeBrush}"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="PID:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FrozenEntry.ProcessId}" FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Service Guess:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FrozenEntry.ServiceGuess}" FontSize="12" Margin="0,3" Foreground="#FF5555" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Payload Size:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,3">
                                                <Run Text="{Binding FrozenEntry.DataSize, Mode=OneWay}"/>
                                                <Run Text=" bytes" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </TextBlock>
                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Direction:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="4" Grid.Column="1" FontSize="12" Margin="0,3" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="⬆ OUTBOUND"/>
                                                        <Setter Property="Foreground" Value="{StaticResource AccentCyanBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding FrozenEntry.Direction}" Value="Inbound">
                                                                <Setter Property="Text" Value="⬇ INBOUND"/>
                                                                <Setter Property="Foreground" Value="{StaticResource AccentMagentaBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Packet Data (Hex Dump) -->
                                <Border Background="#08FFFFFF" CornerRadius="8" Padding="15" Margin="0,0,0,12">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Border Background="#30666666" CornerRadius="5" Padding="10,4">
                                                <TextBlock Text="⬛ RAW DATA" FontWeight="Bold" FontSize="12" Foreground="#888888"/>
                                            </Border>
                                            <TextBlock Text="Packet Capture" Foreground="{StaticResource TextSecondaryBrush}" 
                                                       FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </StackPanel>
                                        <Border Background="#05FFFFFF" CornerRadius="4" Padding="12">
                                            <TextBlock Text="{Binding FrozenEntry.PacketHexDump}" 
                                                       FontFamily="{StaticResource MonoFont}" 
                                                       FontSize="11" Foreground="#667788"
                                                       TextWrapping="Wrap" LineHeight="18"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Timing -->
                                <Border Background="#10888888" CornerRadius="8" Padding="15">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Border Background="#40888888" CornerRadius="5" Padding="10,4">
                                                <TextBlock Text="⏱ TIMING" FontWeight="Bold" FontSize="12" Foreground="#AAAAAA"/>
                                            </Border>
                                        </StackPanel>
                                        <Grid Margin="8,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Captured:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FrozenEntry.Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss.fff}}" FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="UTC Offset:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FrozenEntry.UtcOffset}" FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="0,3"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
