<Window x:Class="FirewallController.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📋 Debug Log"
        Height="400" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundDarkBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Button Grid.Row="0" Content="Очистить" Click="Clear_Click" 
                Style="{StaticResource DangerButton}" 
                HorizontalAlignment="Left" Padding="15,8" Margin="0,0,0,10"/>
        
        <TextBox Grid.Row="1" x:Name="LogText" 
                 IsReadOnly="True" 
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Background="{StaticResource BackgroundMediumBrush}"
                 Foreground="{StaticResource AccentCyanBrush}"
                 FontFamily="Consolas"
                 FontSize="12"
                 Padding="10"/>
    </Grid>
</Window>

