<Window x:Class="FirewallController.ProcessFilterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Фильтр процесса" 
        Height="360" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1a1a2e">
    
    <StackPanel Margin="35,40,35,35">
        
        <!-- Title -->
        <TextBlock Text="🔍 МОНИТОРИНГ ТРАФИКА" 
                   FontSize="22" 
                   FontWeight="Bold" 
                   Foreground="#00d4ff"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,30"/>

        <!-- Label -->
        <TextBlock Text="Введите имя процесса (или оставьте пустым для всех):"
                   Foreground="White" 
                   FontSize="14"
                   Margin="0,0,0,15"/>

        <!-- Input Field -->
        <Border Background="#252545" 
                BorderBrush="#00d4ff" 
                BorderThickness="2" 
                CornerRadius="6"
                Height="50"
                Margin="0,0,0,35">
            <TextBox x:Name="ProcessNameBox"
                     Background="Transparent"
                     Foreground="White"
                     FontSize="16"
                     BorderThickness="0"
                     Padding="15,0"
                     VerticalContentAlignment="Center"
                     CaretBrush="White"/>
        </Border>

        <!-- Buttons -->
        <Grid Height="50">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="0"
                    Content="ОТМЕНА" 
                    Background="#ff3366"
                    Foreground="White"
                    FontSize="15"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="Cancel_Click"/>
                    
            <Button Grid.Column="2"
                    Content="ОТКРЫТЬ МОНИТОР" 
                    Background="#00d4ff"
                    Foreground="#1a1a2e"
                    FontSize="15"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="Ok_Click"/>
        </Grid>
    </StackPanel>
</Window>
