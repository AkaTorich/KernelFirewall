<views:HackerWindow x:Class="HackerFirewall.Views.ProcessFilterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:HackerFirewall.Views"
        Title="PROCESS FILTER"
        Height="150" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Border Background="{StaticResource TerminalBlackBrush}"
            BorderBrush="#FFFF00" BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <Border Grid.Row="0" Background="{StaticResource PanelBgBrush}"
                BorderBrush="{StaticResource DimGreenBrush}" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Height="28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text=" PROCESS FILTER" FontFamily="{StaticResource TerminalFont}"
                           Foreground="{StaticResource CyanAccentBrush}" FontWeight="Bold" FontSize="11"
                           VerticalAlignment="Center" Margin="6,0"/>
                <Button Grid.Column="1" Content="X" Click="Cancel_Click" Width="28" Height="22" Padding="0"
                        FontSize="11" VerticalContentAlignment="Center" Foreground="{StaticResource AlertRedBrush}" Margin="0,0,2,0"/>
            </Grid>
        </Border>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="12,10">
            <TextBlock Text="FILTER BY PROCESS NAME:" Foreground="{StaticResource DimGreenBrush}" Margin="0,0,0,6"/>
            <TextBox x:Name="FilterTextBox" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Click="Ok_Click" IsDefault="True" Margin="0,0,6,0" Width="80" Padding="6,2">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{StaticResource SuccessIcon}" Width="14" Height="14" Margin="0,0,4,0"/>
                        <TextBlock Text="OK" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Click="Cancel_Click" IsCancel="True" Width="90" Padding="6,2">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{StaticResource CloseIcon}" Width="14" Height="14" Margin="0,0,4,0"/>
                        <TextBlock Text="CANCEL" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
    </Border>
</views:HackerWindow>
