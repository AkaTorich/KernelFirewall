<views:HackerWindow x:Class="HackerFirewall.Views.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:HackerFirewall.Views"
        xmlns:controls="clr-namespace:HackerFirewall.Controls"
        Title="SYSTEM LOG"
        Height="500" Width="800"
        WindowStartupLocation="CenterScreen">

    <Border Background="{StaticResource TerminalBlackBrush}"
            BorderBrush="#FFFF00" BorderThickness="1">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Grid.Row="0" Background="{StaticResource PanelBgBrush}"
                    BorderBrush="{StaticResource DimGreenBrush}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Height="30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text=" SYSTEM LOG" FontFamily="{StaticResource TerminalFont}"
                               Foreground="{StaticResource AmberBrush}" FontWeight="Bold" FontSize="12"
                               VerticalAlignment="Center" Margin="6,0,12,0">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FFAA00" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <Button Grid.Column="1" Click="Clear_Click" Padding="6,2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource RemoveIcon}" Width="14" Height="14" Margin="0,0,4,0"/>
                            <TextBlock Text="CLEAR" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Window Buttons -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,2,0">
                        <Button Content="—" Click="Minimize_Click" Width="30" Height="24" Padding="0" FontSize="14" VerticalContentAlignment="Center"/>
                        <Button Content="□" Click="Maximize_Click" Width="30" Height="24" Padding="0" FontSize="13" VerticalContentAlignment="Center"/>
                        <Button Content="X" Click="CloseWindow_Click" Width="30" Height="24" Padding="0" FontSize="12"
                                VerticalContentAlignment="Center" Foreground="{StaticResource AlertRedBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Log Text -->
            <TextBox Grid.Row="1" x:Name="LogText"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     AcceptsReturn="True"
                     FontFamily="{StaticResource TerminalFont}"
                     FontSize="11"
                     Foreground="{StaticResource DarkGreenBrush}"
                     Background="{StaticResource TerminalBlackBrush}"
                     BorderThickness="0" Margin="4"
                     CaretBrush="{StaticResource MatrixGreenBrush}"/>
        </Grid>

        <controls:ScanlineOverlay/>
    </Grid>
    </Border>
</views:HackerWindow>
