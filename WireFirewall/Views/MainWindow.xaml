<views:HackerWindow x:Class="HackerFirewall.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:HackerFirewall.Views"
        xmlns:controls="clr-namespace:HackerFirewall.Controls"
        xmlns:conv="clr-namespace:HackerFirewall.Converters"
        Title="WIRE FIREWALL v3.0"
        Height="850" Width="1350" MinWidth="1000" MinHeight="700"
        WindowStartupLocation="CenterScreen">

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveSessionCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding LoadSessionCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <conv:BoolToFirewallToggleConverter x:Key="BoolToToggle"/>
        <conv:BoolToTerminalStatusConverter x:Key="BoolToStatus"/>
        <conv:BlockedToBrushConverter x:Key="BlockedBrush"/>
    </Window.Resources>

    <Border Background="{StaticResource TerminalBlackBrush}"
            BorderBrush="{StaticResource DimGreenBrush}" BorderThickness="1">
    <Grid>
        <!-- Main Content -->
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Custom Title Bar -->
            <Border Grid.Row="0" Background="{StaticResource PanelBgBrush}"
                    BorderBrush="{StaticResource DimGreenBrush}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Height="30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Title + Menu -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text=" WIRE FIREWALL" FontFamily="{StaticResource TerminalFont}"
                                   Foreground="{StaticResource MatrixGreenBrush}" FontWeight="Bold" FontSize="12"
                                   VerticalAlignment="Center" Margin="6,0,8,0">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#00FF00" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="v3.0" FontFamily="{StaticResource TerminalFont}"
                                   Foreground="{StaticResource DimGreenBrush}" FontSize="10"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Menu Background="Transparent" VerticalAlignment="Center">
                            <MenuItem Header="FILE">
                                <MenuItem Header="SAVE SESSION  Ctrl+S" Command="{Binding SaveSessionCommand}"/>
                                <MenuItem Header="LOAD SESSION  Ctrl+O" Command="{Binding LoadSessionCommand}"/>
                                <Separator/>
                                <MenuItem Header="EXIT" Click="Exit_Click"/>
                            </MenuItem>
                            <MenuItem Header="TOOLS">
                                <MenuItem Header="TRAFFIC MONITOR" Click="OpenTrafficMonitor_Click"/>
                                <MenuItem Header="SYSTEM LOG" Click="OpenLog_Click"/>
                            </MenuItem>
                        </Menu>
                    </StackPanel>

                    <!-- Window Buttons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,2,0">
                        <Button Content="—" Click="Minimize_Click" Width="30" Height="24" Padding="0"
                                FontSize="14" VerticalContentAlignment="Center"/>
                        <Button x:Name="MaxBtn" Content="□" Click="Maximize_Click" Width="30" Height="24" Padding="0"
                                FontSize="13" VerticalContentAlignment="Center"/>
                        <Button Content="X" Click="CloseWindow_Click" Width="30" Height="24" Padding="0"
                                FontSize="12" VerticalContentAlignment="Center" Foreground="{StaticResource AlertRedBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Row 1: Status Bar -->
            <Border Grid.Row="1" BorderBrush="{StaticResource DimGreenBrush}" BorderThickness="0,0,0,1" Padding="10,6" Margin="0,0,0,0"
                    Background="{StaticResource PanelBgBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="STATUS: " Foreground="{StaticResource DimGreenBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding StatusText}" Foreground="{StaticResource MatrixGreenBrush}" FontWeight="Bold" Margin="0,0,20,0"
                               Effect="{StaticResource GreenGlow}"/>

                    <TextBlock Grid.Column="2" Text="BLOCKED: " Foreground="{StaticResource DimGreenBrush}"/>
                    <TextBlock Grid.Column="3" Text="{Binding PacketsBlocked}" Foreground="{StaticResource AlertRedBrush}" FontWeight="Bold" Margin="0,0,20,0"/>

                    <TextBlock Grid.Column="4" Text="ALLOWED: " Foreground="{StaticResource DimGreenBrush}"/>
                    <TextBlock Grid.Column="5" Text="{Binding PacketsAllowed}" Foreground="{StaticResource DarkGreenBrush}" FontWeight="Bold" Margin="0,0,20,0"/>

                    <Button Grid.Column="7" Content="{Binding IsFirewallEnabled, Converter={StaticResource BoolToToggle}}"
                            Command="{Binding ToggleFirewallCommand}" Margin="0,0,4,0" Padding="8,2"/>
                    <Button Grid.Column="8" Content="MONITOR" Click="OpenTrafficMonitor_Click" Padding="8,2"/>
                </Grid>
            </Border>

            <!-- Row 2: Main 3-Column Layout -->
            <Grid Grid.Row="2" Margin="4,4,4,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="250"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*" MinWidth="250"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="1.2*" MinWidth="300"/>
                </Grid.ColumnDefinitions>

                <!-- Column 0: Process Scanner -->
                <controls:GlowBorder Grid.Column="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="PROCESS SCANNER" Foreground="{StaticResource CyanAccentBrush}" FontWeight="Bold" Margin="0,0,0,2"/>

                        <!-- Filter + Buttons compact -->
                        <WrapPanel Grid.Row="1" Margin="0,0,0,2">
                            <Button Content="REFRESH" Command="{Binding RefreshProcessesCommand}" Margin="0,0,3,0" Padding="6,2"/>
                            <Button Content="ALL" Command="{Binding SelectAllProcessesCommand}" Margin="0,0,3,0" Padding="6,2"/>
                            <Button Content="NONE" Command="{Binding DeselectAllProcessesCommand}" Margin="0,0,6,0" Padding="6,2"/>
                            <CheckBox Content="Sys" IsChecked="{Binding ShowSystemProcesses}" Margin="0,0,6,0"/>
                            <CheckBox Content="Dup" IsChecked="{Binding ShowAllInstances}"/>
                        </WrapPanel>

                        <!-- Process Table -->
                        <DataGrid Grid.Row="2" ItemsSource="{Binding RunningProcesses}"
                                  SelectedItem="{Binding SelectedProcess}" Margin="0,0,0,2"
                                  CanUserSortColumns="True">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="24" CanUserSort="False">
                                    <DataGridTemplateColumn.HeaderTemplate>
                                        <DataTemplate><TextBlock Text="✓" Foreground="{StaticResource CyanAccentBrush}"/></DataTemplate>
                                    </DataGridTemplateColumn.HeaderTemplate>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="NAME" Binding="{Binding ProcessName}" Width="*" SortDirection="Ascending">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource DarkGreenBrush}"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            <Setter Property="ToolTip" Value="{Binding ExecutablePath}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="50">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource DimCyanBrush}"/>
                                            <Setter Property="FontSize" Value="10"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="OUT" Binding="{Binding PacketsSent}" Width="45" SortMemberPath="PacketsSent">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource AmberBrush}"/>
                                            <Setter Property="FontSize" Value="10"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="IN" Binding="{Binding PacketsRecv}" Width="45" SortMemberPath="PacketsRecv">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource DarkGreenBrush}"/>
                                            <Setter Property="FontSize" Value="10"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="BLK" Binding="{Binding PacketsBlockedCount}" Width="45" SortMemberPath="PacketsBlockedCount">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource AlertRedBrush}"/>
                                            <Setter Property="FontSize" Value="10"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Process Actions compact -->
                        <WrapPanel Grid.Row="3">
                            <Button Content="BLOCK" Command="{Binding BlockSelectedProcessCommand}" Margin="0,0,3,0" Padding="6,2"/>
                            <Button Content="BLOCK ALL" Command="{Binding BlockSelectedProcessesCommand}" Margin="0,0,3,0" Padding="6,2"/>
                            <Button Content="BY NAME" Command="{Binding BlockByNameCommand}" Margin="0,0,3,0" Padding="6,2"/>
                            <Button Content="PATH" Command="{Binding UseSelectedProcessPathCommand}" Padding="6,2"/>
                        </WrapPanel>
                    </Grid>
                </controls:GlowBorder>

                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

                <!-- Column 2: Blocked Apps -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="Auto" MinHeight="80"/>
                    </Grid.RowDefinitions>

                    <controls:GlowBorder Grid.Row="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="BLOCKED APPS" Foreground="{StaticResource AlertRedBrush}" FontWeight="Bold" Margin="0,0,0,2"/>

                            <ListBox Grid.Row="1" ItemsSource="{Binding BlockedApps}"
                                     SelectedItem="{Binding SelectedBlockedApp}" Margin="0,0,0,2">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ApplicationName}" Foreground="{StaticResource DarkGreenBrush}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <WrapPanel Grid.Row="2">
                                <Button Content="UNBLOCK" Command="{Binding UnblockSelectedAppCommand}" Margin="0,0,3,0" Padding="6,2"/>
                                <Button Content="UNBLOCK ALL" Command="{Binding UnblockAllAppsCommand}" Padding="6,2"/>
                            </WrapPanel>
                        </Grid>
                    </controls:GlowBorder>

                    <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"/>

                    <!-- Session Panel -->
                    <controls:GlowBorder Grid.Row="2">
                        <StackPanel>
                            <TextBlock Text="SESSION" Foreground="{StaticResource AmberBrush}" FontWeight="Bold" Margin="0,0,0,2"/>
                            <WrapPanel>
                                <Button Content="SAVE" Command="{Binding SaveSessionCommand}" Margin="0,0,3,0" Padding="6,2"/>
                                <Button Content="LOAD" Command="{Binding LoadSessionCommand}" Margin="0,0,3,0" Padding="6,2"/>
                                <Button Content="RECONNECT" Command="{Binding ConnectToDriverCommand}" Padding="6,2"/>
                            </WrapPanel>
                        </StackPanel>
                    </controls:GlowBorder>
                </Grid>

                <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

                <!-- Column 4: Filtering Rules -->
                <controls:GlowBorder Grid.Column="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="FILTERING RULES" Foreground="{StaticResource CyanAccentBrush}" FontWeight="Bold" Margin="0,0,0,2"/>

                        <!-- New Rule Form -->
                        <Border Grid.Row="1" BorderBrush="{StaticResource VeryDimGreenBrush}" BorderThickness="1" Padding="6" Margin="0,0,0,6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Path:" Foreground="{StaticResource DimGreenBrush}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding NewRulePath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,3"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Ports:" Foreground="{StaticResource DimGreenBrush}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding NewRulePorts, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,3"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="IPs:" Foreground="{StaticResource DimGreenBrush}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding NewRuleIps, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,3"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Action:" Foreground="{StaticResource DimGreenBrush}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,3">
                                    <RadioButton Content="BLOCK" GroupName="Action" Foreground="{StaticResource AlertRedBrush}" FontFamily="{StaticResource TerminalFont}"
                                                 IsChecked="True" Checked="ActionBlock_Checked" Margin="0,0,10,0"/>
                                    <RadioButton Content="ALLOW" GroupName="Action" Foreground="{StaticResource DarkGreenBrush}" FontFamily="{StaticResource TerminalFont}"
                                                 Checked="ActionAllow_Checked" Margin="0,0,10,0"/>
                                    <RadioButton Content="RESTRICT" GroupName="Action" Foreground="{StaticResource AmberBrush}" FontFamily="{StaticResource TerminalFont}"
                                                 Checked="ActionRestrict_Checked"/>
                                </StackPanel>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Dir:" Foreground="{StaticResource DimGreenBrush}" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="4" Grid.Column="1" SelectedIndex="2" SelectionChanged="Direction_Changed" Margin="0,0,0,3">
                                    <ComboBoxItem Content="ANY"/>
                                    <ComboBoxItem Content="INPUT"/>
                                    <ComboBoxItem Content="OUTPUT"/>
                                </ComboBox>

                                <Button Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                                        Content="ADD RULE" Command="{Binding AddRuleCommand}" HorizontalAlignment="Stretch" Margin="0,3,0,0" Padding="6,2"/>
                            </Grid>
                        </Border>

                        <!-- Rules List -->
                        <ListBox Grid.Row="2" ItemsSource="{Binding Rules}"
                                 SelectedItem="{Binding SelectedRule}" Margin="0,0,0,4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding ActionDisplay}" FontWeight="Bold" Width="80"
                                                   Foreground="{StaticResource DarkGreenBrush}"/>
                                        <TextBlock Text="{Binding ApplicationName}" Width="100" TextTrimming="CharacterEllipsis"
                                                   Foreground="{StaticResource DarkGreenBrush}"/>
                                        <TextBlock Text=" " Foreground="{StaticResource DimGreenBrush}"/>
                                        <TextBlock Text="{Binding DirectionDisplay}" Foreground="{StaticResource DimCyanBrush}" Width="35"/>
                                        <TextBlock Text=" P:" Foreground="{StaticResource DimGreenBrush}"/>
                                        <TextBlock Text="{Binding PortsDisplay}" Foreground="{StaticResource AmberBrush}" Width="70" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text=" IP:" Foreground="{StaticResource DimGreenBrush}"/>
                                        <TextBlock Text="{Binding IpsDisplay}" Foreground="{StaticResource DimCyanBrush}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Rule Actions -->
                        <WrapPanel Grid.Row="3">
                            <Button Content="▲" Command="{Binding MoveRuleUpCommand}" Margin="0,0,2,0" Padding="6,2" Width="24" ToolTip="Move rule up (higher priority)"/>
                            <Button Content="▼" Command="{Binding MoveRuleDownCommand}" Margin="0,0,6,0" Padding="6,2" Width="24" ToolTip="Move rule down (lower priority)"/>
                            <Button Content="DELETE" Command="{Binding RemoveSelectedRuleCommand}" Margin="0,0,3,0" Padding="6,2"/>
                            <Button Content="CLEAR ALL" Command="{Binding ClearAllRulesCommand}" Padding="6,2"/>
                        </WrapPanel>
                    </Grid>
                </controls:GlowBorder>
            </Grid>

            <!-- Row 3: Footer -->
            <Border Grid.Row="3" Padding="4,2"
                    BorderBrush="{StaticResource DimGreenBrush}" BorderThickness="0,1,0,0">
                <TextBlock FontSize="10" Foreground="{StaticResource VeryDimGreenBrush}" HorizontalAlignment="Center">
                    <Run Text="WIRE FIREWALL v3.0  //  "/>
                    <Run Text="{Binding IsConnected, Converter={StaticResource BoolToStatus}, Mode=OneWay}" Foreground="{StaticResource DimGreenBrush}"/>
                </TextBlock>
            </Border>

            <!-- Row 4: Resize Grip -->
            <Border Grid.Row="4" Height="4" Background="{StaticResource PanelBgBrush}" Cursor="SizeNWSE"/>
        </Grid>

        <!-- Scanline Overlay -->
        <controls:ScanlineOverlay/>
    </Grid>
    </Border>
</views:HackerWindow>
