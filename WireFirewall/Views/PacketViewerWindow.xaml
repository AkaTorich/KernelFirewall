<views:HackerWindow x:Class="HackerFirewall.Views.PacketViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:HackerFirewall.Views"
        xmlns:controls="clr-namespace:HackerFirewall.Controls"
        Title="PACKET VIEWER"
        Height="700" Width="900" MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen">

    <Border Background="{StaticResource TerminalBlackBrush}"
            BorderBrush="#FFFF00" BorderThickness="1">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{StaticResource PanelBgBrush}"
                    BorderBrush="{StaticResource DimGreenBrush}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Height="30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text=" PACKET VIEWER" FontFamily="{StaticResource TerminalFont}"
                               Foreground="{StaticResource MatrixGreenBrush}" FontWeight="Bold" FontSize="12"
                               VerticalAlignment="Center" Margin="6,0,12,0">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#00FF00" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <TextBlock Grid.Column="1" x:Name="SummaryText" VerticalAlignment="Center"
                               Foreground="{StaticResource DimGreenBrush}" FontSize="11"/>

                    <Button Grid.Column="2" Click="CopyAll_Click" Padding="6,2"
                            VerticalAlignment="Center" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{StaticResource CopyIcon}" Width="14" Height="14" Margin="0,0,4,0"/>
                            <TextBlock Text="COPY ALL" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,2,0">
                        <Button Content="—" Click="Minimize_Click" Width="30" Height="24" Padding="0" FontSize="14" VerticalContentAlignment="Center"/>
                        <Button Content="□" Click="Maximize_Click" Width="30" Height="24" Padding="0" FontSize="13" VerticalContentAlignment="Center"/>
                        <Button Content="X" Click="CloseWindow_Click" Width="30" Height="24" Padding="0" FontSize="12"
                                VerticalContentAlignment="Center" Foreground="{StaticResource AlertRedBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Layer Tree -->
            <TreeView Grid.Row="1" x:Name="PacketTree" Margin="4"
                      Background="{StaticResource TerminalBlackBrush}"
                      BorderBrush="{StaticResource DimGreenBrush}" BorderThickness="1"
                      FontFamily="{StaticResource TerminalFont}" FontSize="12"
                      Foreground="{StaticResource DarkGreenBrush}">
                <TreeView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Copy Value" Click="CopyValue_Click"/>
                        <MenuItem Header="Copy Branch" Click="CopyBranch_Click"/>
                        <MenuItem Header="Copy All" Click="CopyAll_Click"/>
                    </ContextMenu>
                </TreeView.ContextMenu>
            </TreeView>

            <GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource DimGreenBrush}"/>

            <!-- Hex Dump -->
            <Border Grid.Row="3" Margin="4,0,4,4"
                    BorderBrush="{StaticResource DimGreenBrush}" BorderThickness="1"
                    Background="{StaticResource TerminalBlackBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text=" HEX DUMP" Foreground="{StaticResource DimCyanBrush}"
                               FontWeight="Bold" FontSize="11" Margin="4,2"/>
                    <TextBox Grid.Row="1" x:Name="HexDumpText"
                             IsReadOnly="True" TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="{StaticResource TerminalFont}" FontSize="11"
                             Foreground="{StaticResource DimGreenBrush}"
                             Background="{StaticResource TerminalBlackBrush}"
                             BorderThickness="0" Margin="4,0,4,4"
                             CaretBrush="{StaticResource MatrixGreenBrush}"/>
                </Grid>
            </Border>
        </Grid>

        <controls:ScanlineOverlay/>
    </Grid>
    </Border>
</views:HackerWindow>
